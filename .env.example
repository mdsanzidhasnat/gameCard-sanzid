# WooCommerce API Configuration
WORDPRESS_URL=https://your-wordpress-site.com
WC_CONSUMER_KEY=your_woocommerce_consumer_key
WC_CONSUMER_SECRET=your_woocommerce_consumer_secret

# Revalidation & ISR Configuration
REVALIDATE_SECRET=your_secure_revalidation_token

# Supabase Configuration (if using for authentication/data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Add additional environment variables below
# NEXT_PUBLIC_API_URL=https://api.example.com
# Analytics or third-party service keys can be added here
